                    <mxGeometry x="1292" y="478" width="295" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_box" value="Use Case Flow: User follows another user" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#B45309;strokeWidth=2;verticalAlign=top;align=left;fontSize=12;fontStyle=1;fontColor=#7C4A00;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="990" width="1540" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="flow_steps" value="(1) User POST /api/v1/followers via API Gateway (HTTPS)&amp;nbsp;&lt;div&gt;(2) Gateway routes to follower-service (validates JWT from Keycloak)&amp;nbsp;&lt;/div&gt;&lt;div&gt;(3) follower-service → user-service [Sync Feign]: GET /users/{id} — check target user exists&amp;nbsp;&lt;/div&gt;&lt;div&gt;(4) follower-service saves FollowRelation → publishes 'UserFollowed' to Kafka [Async pub/sub] (via Outbox)&amp;nbsp;&lt;/div&gt;&lt;div&gt;(5) article-service consumes 'UserFollowed' → updates user feed&lt;br/&gt;(6) notification-service consumes 'UserFollowed' from Kafka&amp;nbsp;&lt;/div&gt;&lt;div&gt;(7) notification-service → user-service [Sync Feign]: check recipient ACTIVE &amp;amp; preferences&amp;nbsp;&lt;/div&gt;&lt;div&gt;(8) notification-service sends notification via Provider&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1015" width="1520" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="e_kafka_noti" style="endArrow=classic;startArrow=none;dashed=1;dashPattern=8 6;html=1;rounded=0;strokeColor=#9333EA;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;exitX=0.85;exitY=1;entryX=0.25;entryY=0;" edge="1" parent="1" source="kafka" target="svc_notification">
                    <mxGeometry relative="1" as="geometry"/>
