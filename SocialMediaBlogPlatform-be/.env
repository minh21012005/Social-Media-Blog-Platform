# Local development environment for Social Media Blog Platform backend.
# Values are read by Spring Boot via optional:file:.env[.properties] when services run from this folder.

CONFIG_SERVER_URL=http://localhost:8888
EUREKA_SERVER_URL=http://localhost:8761/eureka/
CORS_ALLOWED_ORIGINS=http://localhost:5173

USER_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/social_blog_users
USER_SERVICE_DB_USERNAME=social_blog
USER_SERVICE_DB_PASSWORD=social_blog

JWT_ISSUER=social-media-blog-platform
JWT_KEY_ID=social-blog-local-dev
JWT_PRIVATE_KEY_PATH=./config/jwt/dev-private-key.pem
JWT_PUBLIC_KEY_PATH=./config/jwt/dev-public-key.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=Lax
