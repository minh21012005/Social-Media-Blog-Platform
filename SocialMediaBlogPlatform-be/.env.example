# Local development environment for Social Media Blog Platform backend.
# Copy this file to .env for local runs. Spring Boot imports .env via optional:file:.env[.properties].

CONFIG_SERVER_URL=http://localhost:8888
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_INSTANCE_IP_ADDRESS=127.0.0.1
EUREKA_INSTANCE_HOSTNAME=localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173

USER_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/social_blog_users
USER_SERVICE_DB_USERNAME=social_blog
USER_SERVICE_DB_PASSWORD=social_blog

ARTICLE_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/social_blog_articles
ARTICLE_SERVICE_DB_USERNAME=social_blog
ARTICLE_SERVICE_DB_PASSWORD=social_blog

COMMENT_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/social_blog_comments
COMMENT_SERVICE_DB_USERNAME=social_blog
COMMENT_SERVICE_DB_PASSWORD=social_blog

INTERACTION_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/social_blog_interactions
INTERACTION_SERVICE_DB_USERNAME=social_blog
INTERACTION_SERVICE_DB_PASSWORD=social_blog

FOLLOWER_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/social_blog_followers
FOLLOWER_SERVICE_DB_USERNAME=social_blog
FOLLOWER_SERVICE_DB_PASSWORD=social_blog

NOTIFICATION_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/social_blog_notifications
NOTIFICATION_SERVICE_DB_USERNAME=social_blog
NOTIFICATION_SERVICE_DB_PASSWORD=social_blog

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=social-blog/avatars
CLOUDINARY_ARTICLE_FOLDER=social-blog/articles
USER_AVATAR_MAX_FILE_SIZE=5MB
USER_AVATAR_MAX_REQUEST_SIZE=5MB
ARTICLE_MEDIA_MAX_FILE_SIZE=10MB
ARTICLE_MEDIA_MAX_REQUEST_SIZE=10MB

JWT_ISSUER=social-media-blog-platform
JWT_KEY_ID=social-blog-local-dev
JWT_PRIVATE_KEY_PATH=./config/jwt/dev-private-key.pem
JWT_PUBLIC_KEY_PATH=./config/jwt/dev-public-key.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=Lax

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Outbox Relay Scheduler
OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_FIXED_DELAY_MS=5000
