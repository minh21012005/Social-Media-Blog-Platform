# Install this as /etc/nginx/sites-available/api.subtrack.click after obtaining
# the TLS certificate for api.subtrack.click (for example with Certbot).
server {
    listen 80;
    listen [::]:80;
    server_name api.subtrack.click;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.subtrack.click;

    ssl_certificate /etc/letsencrypt/live/api.subtrack.click/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.subtrack.click/privkey.pem;

    client_max_body_size 12m;

    location /ws/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 65s;
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
