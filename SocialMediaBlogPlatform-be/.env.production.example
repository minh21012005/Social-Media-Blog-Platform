# EC2 production environment for https://api.subtrack.click
# Copy to .env.production and never commit the resulting file.

# One private RDS for PostgreSQL instance, one logical database and role per service.
# Replace <rds-endpoint> with the RDS endpoint. Keep sslmode=require enabled.
USER_SERVICE_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/social_blog_users?sslmode=require
USER_SERVICE_DB_USERNAME=user_service
USER_SERVICE_DB_PASSWORD=

ARTICLE_SERVICE_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/social_blog_articles?sslmode=require
ARTICLE_SERVICE_DB_USERNAME=article_service
ARTICLE_SERVICE_DB_PASSWORD=

COMMENT_SERVICE_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/social_blog_comments?sslmode=require
COMMENT_SERVICE_DB_USERNAME=comment_service
COMMENT_SERVICE_DB_PASSWORD=

INTERACTION_SERVICE_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/social_blog_interactions?sslmode=require
INTERACTION_SERVICE_DB_USERNAME=interaction_service
INTERACTION_SERVICE_DB_PASSWORD=

FOLLOWER_SERVICE_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/social_blog_followers?sslmode=require
FOLLOWER_SERVICE_DB_USERNAME=follower_service
FOLLOWER_SERVICE_DB_PASSWORD=

NOTIFICATION_SERVICE_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/social_blog_notifications?sslmode=require
NOTIFICATION_SERVICE_DB_USERNAME=notification_service
NOTIFICATION_SERVICE_DB_PASSWORD=

CORS_ALLOWED_ORIGINS=https://subtrack.click
REFRESH_TOKEN_COOKIE_SECURE=true
# subtrack.click and api.subtrack.click are same-site, so Lax is appropriate.
REFRESH_TOKEN_COOKIE_SAME_SITE=Lax

JWT_ISSUER=subtrack
JWT_KEY_ID=subtrack-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# Must match VITE_GOOGLE_CLIENT_ID configured in Vercel.
GOOGLE_CLIENT_ID=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=subtrack/avatars
CLOUDINARY_ARTICLE_FOLDER=subtrack/articles
